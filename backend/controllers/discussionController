const Discussion = require("../models/Discussion");
const Reply = require("../models/Reply");


// CREATE DISCUSSION THREAD
const createDiscussion = async (req, res) => {
  try {

    console.log("BODY:", req.body); // 👈 ADD THIS

    const { postId, userId } = req.body;

    let discussion = await Discussion.findOne({ postId });

    if (discussion) {
      return res.json({ discussion });
    }

    const newDiscussion = new Discussion({
      postId,
      userId,
      title: "Discussion",
      content: "Start chatting"
    });

    await newDiscussion.save();

    res.json({ discussion: newDiscussion });

  } catch (error) {
    console.log("ERROR:", error.message); // 👈 ADD THIS
    res.status(500).json({ error: error.message });
  }
};
// GET DISCUSSIONS FOR A POST
const getPostDiscussions = async (req, res) => {
  try {

    const { postId } = req.params;

    const discussions = await Discussion.find({ postId })
      .populate("userId", "username");

    res.json(discussions);

  } catch (error) {
    res.status(500).json({ error: error.message });
  }
};


